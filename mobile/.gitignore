# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# Firebase configs (drop these locally; they're per-environment)
google-services.json
GoogleService-Info.plist

# Firebase Admin SDK / FCM v1 service account keys — contain a private key,
# NEVER commit. Upload via `eas credentials` or Expo dashboard instead.
*firebase-adminsdk*.json
google-service-account*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

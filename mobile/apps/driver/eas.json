{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://taxi-api-cy7a.onrender.com/api",
        "EXPO_PUBLIC_PUSHER_KEY": "your-dev-pusher-key",
        "EXPO_PUBLIC_PUSHER_CLUSTER": "ap1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://taxi-api-cy7a.onrender.com/api",
        "EXPO_PUBLIC_PUSHER_KEY": "your-staging-pusher-key",
        "EXPO_PUBLIC_PUSHER_CLUSTER": "ap1"
      },
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "android": { "buildType": "app-bundle" },
      "ios": { "autoIncrement": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://taxi-api-cy7a.onrender.com/api",
        "EXPO_PUBLIC_PUSHER_KEY": "77eb270f5c73dda1665b",
        "EXPO_PUBLIC_PUSHER_CLUSTER": "ap1"
      },
      "channel": "production"
    }
  }
}

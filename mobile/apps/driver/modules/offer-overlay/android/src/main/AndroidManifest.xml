<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Draw the offer overlay on top of any other app. User must grant this
       at runtime via Settings → Apps → AIYL Taxi → "Display over other
       apps". Module exposes hasOverlayPermission() + openOverlaySettings()
       so the JS side can lead the driver through that flow. -->
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

  <application>
    <!-- Native FCM listener — owns the MESSAGING_EVENT intent so offer
         pushes are handled in Kotlin (overlay + ringing notification fire
         even when JS is dead). Shadows expo-notifications' own service for
         this intent; expo-notifications token retrieval still works because
         it talks to Firebase APIs directly. -->
    <service
      android:name="expo.modules.offeroverlay.OfferFirebaseMessagingService"
      android:exported="false">
      <intent-filter>
        <action android:name="com.google.firebase.MESSAGING_EVENT" />
      </intent-filter>
    </service>
  </application>
</manifest>

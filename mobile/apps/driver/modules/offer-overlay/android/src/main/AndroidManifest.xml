<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools">
  <!-- Draw the offer overlay on top of any other app. User must grant this
       at runtime via Settings → Apps → AIYL Taxi → "Display over other
       apps". Module exposes hasOverlayPermission() + openOverlaySettings()
       so the JS side can lead the driver through that flow. -->
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

  <application>
    <!-- Remove expo-notifications' FirebaseMessagingService from the
         merged manifest. Without this, both services are registered for
         MESSAGING_EVENT and FCM picks one non-deterministically — in
         practice it tends to be Expo's, so our overlay-firing handler
         never sees the offer push. With Expo's service stripped, ours
         is the only one and FCM dispatches every message to it.
         Token retrieval still works because JS calls Firebase APIs
         directly via Notifications.getDevicePushTokenAsync. -->
    <service
      android:name="expo.modules.notifications.service.ExpoFirebaseMessagingService"
      tools:node="remove" />

    <service
      android:name="expo.modules.offeroverlay.OfferFirebaseMessagingService"
      android:exported="false">
      <intent-filter>
        <action android:name="com.google.firebase.MESSAGING_EVENT" />
      </intent-filter>
    </service>
  </application>
</manifest>

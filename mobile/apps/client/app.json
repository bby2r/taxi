{
  "expo": {
    "name": "Alif Taxi",
    "slug": "alif-taxi-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "kg.aliftaxi.client",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Нужен доступ к геолокации для определения точки подачи такси"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "kg.aliftaxi.client",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAtbF4MY6NGAfxHyF75anFC6LxLzmjr878"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Нужен доступ к геолокации для определения точки подачи такси"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": []
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/alif-lockup.png",
          "imageWidth": 130,
          "resizeMode": "contain",
          "backgroundColor": "#F4FBFA"
        }
      ],
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Feather.ttf",
            "./assets/fonts/Ionicons.ttf"
          ]
        }
      ]
    ]
  }
}

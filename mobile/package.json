{
  "name": "aiyl-taxi-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "client": "npm --workspace apps/client run start",
    "driver": "npm --workspace apps/driver run start",
    "client:android": "npm --workspace apps/client run android",
    "driver:android": "npm --workspace apps/driver run android",
    "build:client": "npm --workspace apps/client run build:apk",
    "build:driver": "npm --workspace apps/driver run build:apk"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
